FROM oven/bun:1

WORKDIR /usr/src/app

# Copy everything from the context (which is repo root)
COPY . .

# Install dependencies
RUN bun install --frozen-lockfile

# Generate Prisma client
RUN bun run generate:db

# Run Next.js in development mode (no build required)
EXPOSE 3000

CMD ["sh", "-c", "cd apps/web && bun run dev"]
