FROM oven/bun:1

WORKDIR /usr/src/app

COPY . .

RUN bun install --frozen-lockfile

RUN bun run generate:db

# Avoid DB access at image build time (Next.js prerender can trigger Prisma calls)
ENV SKIP_DB=1
RUN cd apps/web && bun run build

EXPOSE 3000

CMD ["sh", "-c", "cd apps/web && bun run start"]
